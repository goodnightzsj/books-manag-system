# ======================================================================
# Books Management System -- environment template
# Copy to `.env` and fill in real secrets before running docker-compose.
# ======================================================================

# --- PostgreSQL ---
POSTGRES_DB=books_db
POSTGRES_USER=books_user
POSTGRES_PASSWORD=books_pass
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Public hostname ---
# This is what nginx uses for server_name and what frontends point at.
# For local dev override to http://localhost:8000 and add localhost origins.
PUBLIC_HOST=books.9962510.xyz
PUBLIC_URL=https://books.9962510.xyz

# --- API ---
API_PORT=8000
SECRET_KEY=please-change-me-to-a-long-random-string
ALLOWED_ORIGINS=https://books.9962510.xyz,http://localhost:3000,http://localhost:3001

# --- Admin bootstrap ---
# Leaving ADMIN_PASSWORD empty will skip automatic admin creation.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# --- Celery ---
CELERY_QUEUES=scan,enrich,maintenance

# --- Nginx ---
HTTP_PORT=80
HTTPS_PORT=443

# --- Frontends ---
ADMIN_WEB_PORT=3000
READER_WEB_PORT=3001
# Browser-facing API base (build-time embedded into Next.js bundles).
# Production: same-origin via nginx proxy at https://books.9962510.xyz
# Dev: http://localhost:8000
PUBLIC_API_BASE=https://books.9962510.xyz

# --- Production image overlay (used by docker-compose.prod.yml) ---
IMAGE_NAMESPACE=helloworldz1024
IMAGE_TAG=latest

# --- Search (Phase 2, optional) ---
# MEILI_URL=http://meilisearch:7700
# MEILI_MASTER_KEY=

# --- External metadata sources ---
DOUBAN_API_URL=https://douban.uieee.com
GOOGLE_BOOKS_API_KEY=
