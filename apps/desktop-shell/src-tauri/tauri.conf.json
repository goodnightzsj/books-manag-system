{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Books Reader",
  "version": "0.1.0",
  "identifier": "com.books.reader.desktop",
  "build": {
    "beforeDevCommand": "cd ../../frontend/reader-web && npm run dev",
    "beforeBuildCommand": "cd ../../frontend/reader-web && npm run build",
    "devUrl": "http://localhost:3001",
    "frontendDist": "../../frontend/reader-web/.next"
  },
  "app": {
    "windows": [
      {
        "title": "Books Reader",
        "width": 1200,
        "height": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
